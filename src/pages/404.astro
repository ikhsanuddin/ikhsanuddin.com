---
import Base from "@/layouts/Base.astro";
---

<Base title="Page Not Found - Ikhsanuddin Syamsuri" description="Page not found">
  <main class="min-h-screen flex flex-col items-center justify-center gap-6">
    <h1 class="text-6xl font-bold">404</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400">
      The page you are looking for does not exist.
    </p>
    <a
      href="/"
      class="px-6 py-3 bg-gradient-to-r from-light-primary to-light-secondary dark:from-dark-secondary dark:to-dark-accent rounded-full font-bold text-white transition-all hover:scale-105"
    >
      Back to home
    </a>
  </main>
</Base>
